{
  "schemaVersion": 1,
  "id": "strawcraft",
  "version": "${version}",
  "name": "StrawCraft",
  "description": "Caecorthus gameplay changes for Wathe.",
  "authors": [
    "Caecorthus"
  ],
  "contact": {
    "homepage": "https://github.com/Caecorthus/StrawCraft",
    "sources": "https://github.com/Caecorthus/StrawCraft"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "org.caecorthus.strawcraft.StrawCraft"
    ],
    "client": [
      "org.caecorthus.strawcraft.client.StrawCraftClient"
    ],
    "cardinal-components": [
      "org.caecorthus.strawcraft.map.StrawCraftComponents"
    ]
  },
  "mixins": [
    "strawcraft.mixins.json"
  ],
  "custom": {
    "cardinal-components": [
      "strawcraft:map_voting"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=21",
    "wathe": "${wathe_version}"
  }
}
